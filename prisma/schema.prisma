generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  passwordHash String?
  role         UserRole   @default(CITIZEN)
  /// Documento del vecino. Se pide una sola vez, al registrarse.
  dni          String?    @unique
  /// Fecha de nacimiento: el registro exige 18 años cumplidos.
  birthDate    DateTime?
  /// Profesión u ocupación declarada por el vecino.
  occupation   String?
  createdAt    DateTime   @default(now())
  proposals    Proposal[]
  comments     Comment[]
  votes        Vote[]
  contributions CitizenContribution[]
}

model Regulation {
  id        String          @id @default(cuid())
  title     String
  type      RegulationType
  number    String?
  summary   String?
  sourceUrl String?
  fileUrl   String?
  fullText  String?
  issuedAt  DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  chunks    DocumentChunk[]
}

model DocumentChunk {
  id           String     @id @default(cuid())
  regulationId String
  content      String
  pageNumber   Int?
  chunkIndex   Int
  embeddingId  String?
  createdAt    DateTime   @default(now())
  regulation   Regulation @relation(fields: [regulationId], references: [id], onDelete: Cascade)
}

model NormativeDocument {
  id              String              @id
  title           String
  documentType    String
  ordinanceNumber String?
  versionDate     DateTime?
  jurisdiction    String
  sourceName      String
  sourcePath      String?
  status          NormativeStatus     @default(HISTORICAL_REFERENCE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  chapters        NormativeChapter[]
  articles        NormativeArticle[]
  ordinances      Ordinance[]         @relation("SourceNormativeDocument")

  @@index([ordinanceNumber])
  @@index([versionDate])
}

model NormativeChapter {
  id            String             @id
  documentId    String
  chapterNumber String
  title         String
  description   String?
  displayOrder  Int
  document      NormativeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  articles      NormativeArticle[]

  @@unique([documentId, chapterNumber])
  @@index([documentId, displayOrder])
}

model NormativeArticle {
  id                String             @id
  documentId        String
  chapterId         String?
  articleNumber     String
  title             String?
  content           String
  normalizedContent String
  metadata          Json               @default("{}")
  status            NormativeStatus    @default(HISTORICAL_REFERENCE)
  displayOrder      Int
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  document          NormativeDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chapter           NormativeChapter?  @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  versions          ArticleVersion[]
  sourceDistricts   District[]
  landUseRules      DistrictLandUseRule[]
  links             NormativeLink[]

  @@unique([documentId, articleNumber])
  @@index([documentId, displayOrder])
  @@index([chapterId])
}

model Ordinance {
  id               String             @id
  number           String             @unique
  title            String
  description      String?
  sanctionDate     DateTime?
  effectiveDate    DateTime?
  status           NormativeStatus    @default(UNKNOWN)
  sourceDocumentId String?
  sourceDocument   NormativeDocument? @relation("SourceNormativeDocument", fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  articleVersions  ArticleVersion[]
}

model ArticleVersion {
  id            String           @id @default(cuid())
  articleId     String
  ordinanceId   String?
  content       String
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  changeType    NormativeChangeType
  notes         String?
  article       NormativeArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  ordinance     Ordinance?       @relation(fields: [ordinanceId], references: [id], onDelete: SetNull)

  @@index([articleId, effectiveFrom])
  @@index([ordinanceId])
}

model District {
  id                   String                  @id
  code                 String                  @unique
  name                 String?
  category             String?
  description          String?
  characterDescription String?
  geometry             Unsupported("geometry")?
  sourceArticleId      String?
  sourceArticle        NormativeArticle?       @relation(fields: [sourceArticleId], references: [id], onDelete: SetNull)
  landUseRules         DistrictLandUseRule[]

  @@index([sourceArticleId])
}

model LandUse {
  id          String                  @id @default(cuid())
  name        String
  category    String?
  description String?
  rules       DistrictLandUseRule[]

  @@unique([name, category])
}

model DistrictLandUseRule {
  id                  String             @id @default(cuid())
  districtId          String
  landUseId           String
  status              LandUseRuleStatus  @default(UNKNOWN)
  conditions          String?
  parkingRequirements String?
  loadingRequirements String?
  sourceArticleId     String?
  sourceReference     String?
  district            District           @relation(fields: [districtId], references: [id], onDelete: Cascade)
  landUse             LandUse            @relation(fields: [landUseId], references: [id], onDelete: Cascade)
  sourceArticle       NormativeArticle?   @relation(fields: [sourceArticleId], references: [id], onDelete: SetNull)

  @@unique([districtId, landUseId, sourceReference])
  @@index([sourceArticleId])
}

model NormativeLink {
  id               String                    @id @default(cuid())
  sourceType       String
  sourceId         String
  articleId        String
  relationshipType NormativeRelationshipType
  notes            String?
  createdBy        String?
  createdAt        DateTime                  @default(now())
  article          NormativeArticle          @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, articleId, relationshipType])
  @@index([articleId])
  @@index([sourceType, sourceId])
}

model City {
  id          String           @id @default(cuid())
  name        String
  province    String?
  country     String
  population  Int?
  areaKm2     Float?
  density     Float?
  climate     String?
  description String?
  similarity  Int              @default(0)
  caseStudies CaseStudy[]
  indicators  UrbanIndicator[]
}

model CaseStudy {
  id        String   @id @default(cuid())
  cityId    String
  title     String
  problem   String
  solution  String
  results   String?
  cost      String?
  sourceUrl String?
  tags      String[]
  createdAt DateTime @default(now())
  city      City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model UrbanIndicator {
  id        String  @id @default(cuid())
  cityId    String
  name      String
  value     Float
  unit      String
  year      Int
  sourceUrl String?
  city      City    @relation(fields: [cityId], references: [id], onDelete: Cascade)
}

model UrbanLayer {
  id               String       @id @default(cuid())
  name             String
  slug             String       @unique
  description      String?
  geometryType     GeometryType
  visibleByDefault Boolean      @default(false)
  features         MapFeature[]
}

model MapFeature {
  id          String                  @id @default(cuid())
  layerId     String
  name        String
  description String?
  properties  Json                    @default("{}")
  geometry    Unsupported("geometry")
  layer       UrbanLayer              @relation(fields: [layerId], references: [id], onDelete: Cascade)

  @@index([layerId])
}

model Proposal {
  id          String         @id @default(cuid())
  title       String
  description String
  status      ProposalStatus @default(DRAFT)
  source      ProposalSource @default(CITIZEN)
  latitude    Float?
  longitude   Float?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdBy   User?          @relation(fields: [createdById], references: [id])
  comments    Comment[]
  citizenContributions CitizenContribution[]
  votes       Vote[]
}

model CitizenContribution {
  id          String                    @id @default(cuid())
  kind        CitizenContributionKind
  name        String
  dni         String
  zone        String
  text        String
  fileName    String?
  axis        String
  /// Por qué Migue sugirió ese eje, con el artículo en el que se apoyó.
  axisReason  String?
  /// false = eje sugerido por Migue, todavía sin revisar. true = lo confirmó una persona.
  axisConfirmed Boolean                 @default(false)
  confidence  String
  status      CitizenContributionStatus @default(NEW)
  /// Autor del aporte. Nullable: los aportes anteriores al login obligatorio no lo tienen.
  /// SetNull y no Cascade: si se borra la cuenta, el aporte queda para el municipio.
  userId      String?
  proposalId  String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  user        User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  proposal    Proposal?                 @relation(fields: [proposalId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([kind])
  @@index([status])
  @@index([proposalId])
  @@index([userId])
}

model Comment {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  body       String
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vote {
  id         String   @id @default(cuid())
  proposalId String
  userId     String
  value      Int      @default(1)
  createdAt  DateTime @default(now())
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([proposalId, userId])
}

model CabinetMeeting {
  id           String        @id @default(cuid())
  title        String
  meetingDate  DateTime
  area         String?
  participants String[]
  notes        String?
  ideas        CabinetIdea[]
  createdAt    DateTime      @default(now())
}

model CabinetIdea {
  id          String         @id @default(cuid())
  meetingId   String
  title       String
  description String
  status      IdeaStatus     @default(NEW)
  proposalId  String?
  createdAt   DateTime       @default(now())
  meeting     CabinetMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model AiQuery {
  id        String   @id @default(cuid())
  question  String
  answer    String?
  sources   Json     @default("[]")
  createdAt DateTime @default(now())
}

model KnowledgeSource {
  id          String              @id @default(cuid())
  kind        KnowledgeSourceKind
  externalId  String?
  title       String
  sourceUrl   String?
  filePath    String?
  mimeType    String?
  status      ProcessingStatus    @default(PENDING)
  rawText     String?
  summary     String?
  metadata    Json                @default("{}")
  wordCount   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  processedAt DateTime?
  chunks      KnowledgeChunk[]

  @@unique([kind, externalId])
  @@index([kind])
  @@index([status])
}

model KnowledgeChunk {
  id            String                       @id @default(cuid())
  sourceId      String
  chunkIndex    Int
  content       String
  tokenEstimate Int                          @default(0)
  metadata      Json                         @default("{}")
  embedding     Unsupported("vector(384)")?
  createdAt     DateTime                     @default(now())
  source        KnowledgeSource              @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([sourceId, chunkIndex])
  @@index([sourceId, chunkIndex])
}

model Meeting {
  id                 String               @id @default(cuid())
  title              String
  kind               MeetingKind          @default(MEETING)
  status             ProcessingStatus     @default(PENDING)
  occurredAt         DateTime?
  location           String?
  description        String?
  language           String               @default("es")
  metadata           Json                 @default("{}")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  mediaFiles         MeetingMedia[]
  participants       MeetingParticipant[]
  transcriptSegments TranscriptSegment[]
  analyses           MeetingAnalysis[]
  insights           MeetingInsight[]
  actionItems        MeetingActionItem[]
}

model MeetingMedia {
  id           String           @id @default(cuid())
  meetingId    String
  kind         MediaKind
  fileName     String
  storagePath  String
  mimeType     String
  sizeBytes    BigInt?
  durationSec  Int?
  status       ProcessingStatus @default(PENDING)
  errorMessage String?
  createdAt    DateTime         @default(now())
  meeting      Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@index([status])
}

model MeetingParticipant {
  id          String  @id @default(cuid())
  meetingId   String
  displayName String
  role        String?
  email       String?
  metadata    Json    @default("{}")
  meeting     Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model TranscriptSegment {
  id            String   @id @default(cuid())
  meetingId     String
  participantId String?
  speakerLabel  String?
  startMs       Int
  endMs         Int
  content       String
  confidence    Float?
  metadata      Json     @default("{}")
  createdAt     DateTime @default(now())
  meeting       Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, startMs])
}

model MeetingAnalysis {
  id          String   @id @default(cuid())
  meetingId   String
  provider    String?
  model       String?
  version     Int      @default(1)
  summary     String
  conclusions Json     @default("[]")
  topics      Json     @default("[]")
  risks       Json     @default("[]")
  citations   Json     @default("[]")
  createdAt   DateTime @default(now())
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([meetingId, version])
}

model MeetingInsight {
  id          String             @id @default(cuid())
  meetingId   String
  kind        MeetingInsightKind
  title       String
  description String
  importance  Int                @default(3)
  evidence    Json               @default("[]")
  createdAt   DateTime           @default(now())
  meeting     Meeting            @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, kind])
}

model MeetingActionItem {
  id          String           @id @default(cuid())
  meetingId   String
  title       String
  description String?
  assignee    String?
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  evidence    Json             @default("[]")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  meeting     Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId, status])
}

model CpuConversation {
  id        String       @id @default(cuid())
  title     String       @default("Nueva consulta")
  ownerKey  String
  userId    String?
  archived  Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  CpuMessage[]

  @@index([ownerKey, archived, updatedAt])
}

model CpuMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           String
  content        String
  citations      Json            @default("[]")
  retrieved      Json            @default("[]")
  isError        Boolean         @default(false)
  createdAt      DateTime        @default(now())
  conversation   CpuConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Feedback ciudadano sobre las respuestas de Migue. Guarda la pregunta, la
// respuesta, la fuente citada y el modelo para poder medir calidad por tipo de
// consulta cuando cambian el chunkeo, el retrieval o el modelo.
model MigueFeedback {
  id              String   @id @default(cuid())
  rating          String // "up" | "down"
  reason          String? // motivo elegido en el chip (solo votos negativos)
  comment         String?
  question        String
  answer          String
  sourceReference String?
  model           String?
  createdAt       DateTime @default(now())

  @@index([rating, createdAt])
}

enum UserRole {
  ADMIN
  OFFICIAL
  TECHNICIAN
  CITIZEN
}

enum RegulationType {
  ORDINANCE
  DECREE
  URBAN_CODE
  BUILDING_CODE
  REPORT
}

enum NormativeStatus {
  DRAFT
  HISTORICAL_REFERENCE
  CURRENT
  MODIFIED
  REPEALED
  UNKNOWN
}

enum NormativeChangeType {
  CREATED
  MODIFIED
  PARTIALLY_MODIFIED
  REPEALED
  REPLACED
}

enum LandUseRuleStatus {
  ALLOWED
  CONDITIONAL
  RESTRICTED
  NOT_ALLOWED
  UNKNOWN
}

enum NormativeRelationshipType {
  APPLIES
  MODIFIES
  REFERENCES
  POTENTIAL_CONFLICT
  SUPPORTS
  REQUIRES_REVIEW
}

enum GeometryType {
  POINT
  LINESTRING
  POLYGON
  MULTIPOLYGON
}

enum ProposalStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  NEEDS_DATA
  FEASIBLE
  NOT_FEASIBLE
  APPROVED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum ProposalSource {
  CITIZEN
  OFFICIAL
  CABINET
  TECHNICAL_TEAM
}

enum CitizenContributionKind {
  PROPOSAL
  CLAIM
  CONTRIBUTION
}

enum CitizenContributionStatus {
  NEW
  LINKED_TO_PROPOSAL
  UNDER_REVIEW
  RESOLVED
  ARCHIVED
}

enum IdeaStatus {
  NEW
  ANALYZING
  CONVERTED_TO_PROPOSAL
  DISCARDED
}

enum KnowledgeSourceKind {
  REGULATION
  REPORT
  WEB_PAGE
  MEETING
  FILE
  MANUAL
}

enum ProcessingStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

enum MeetingKind {
  MEETING
  PUBLIC_HEARING
  CABINET
  TECHNICAL_COMMITTEE
}

enum MediaKind {
  AUDIO
  VIDEO
}

enum MeetingInsightKind {
  DECISION
  COMMITMENT
  RISK
  QUESTION
  CONFLICT
  REGULATION_REFERENCE
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
