NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
DATABASE_URL=""
AUTH_SECRET=""

# Documentos adjuntos de audiencias (Supabase Storage). Crear un bucket PUBLICO
# y pegar su nombre aca (default: "audiencias"). La service role key es opcional
# pero recomendada: los uploads server-side saltean las politicas RLS del bucket.
SUPABASE_HEARINGS_BUCKET="audiencias"
SUPABASE_SERVICE_ROLE_KEY=""

OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="UrbanIA"
# Transcripcion de audiencias (Whisper via OpenRouter). Opcional: default openai/whisper-1
OPENROUTER_TRANSCRIPTION_MODEL="openai/whisper-1"

