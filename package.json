{
  "name": "urbania",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:import:planning-code": "tsx --env-file=.env.local prisma/import-planning-code.ts",
    "db:verify:planning-code": "tsx prisma/verify-planning-code.ts",
    "db:verify:planning-code-db": "tsx --env-file=.env.local prisma/verify-planning-code-db.ts",
    "db:import:geojson": "tsx --env-file=.env.local prisma/import-geojson-layers.ts",
    "db:ingest:knowledge": "tsx --env-file=.env.local prisma/ingest-knowledge.ts",
    "db:ingest:planillas": "tsx --env-file=.env.local prisma/ingest-planillas.ts",
    "db:ingest:planillas-uso": "tsx --env-file=.env.local prisma/ingest-planillas-uso.ts",
    "hearings:ingest": "tsx --env-file=.env.local scripts/ingest-hearings.ts",
    "dev:turbo": "next dev --turbo"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@napi-rs/canvas": "^1.0.2",
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.110.8",
    "@tanstack/react-query": "^5.59.16",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "framer-motion": "^12.42.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "next": "^15.0.3",
    "openai": "^4.73.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
